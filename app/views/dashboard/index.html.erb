<div class="page-header">
  <div>
    <h1 class="page-title">Quantum Bench Results Dashboard</h1>
    <p class="page-subtitle">Benchmark vs Griffiths literature values</p>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-value primary"><%= @total_problems %></div>
    <div class="stat-label">Total Problems</div>
  </div>
  <div class="stat-card">
    <div class="stat-value low"><%= @pass_count %></div>
    <div class="stat-label">Pass Count</div>
  </div>
  <div class="stat-card">
    <div class="stat-value critical"><%= @fail_count %></div>
    <div class="stat-label">Fail Count</div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h2 class="card-title">Problem Results</h2>
  </div>

  <table>
    <thead>
      <tr>
        <th>Problem</th>
        <th>Domain</th>
        <th>Tier</th>
        <th>Benchmark</th>
        <th>Literature Value</th>
        <th>Absolute Error</th>
        <th>Result</th>
      </tr>
    </thead>
    <tbody>
      <% @rows.each do |row| %>
        <tr>
          <td><%= row[:problem].name %></td>
          <td><%= row[:problem].domain %></td>
          <td><%= row[:problem].tier %></td>
          <td><%= row[:benchmark_value].nil? ? "N/A" : row[:benchmark_value] %></td>
          <td><%= row[:llm_value].nil? ? "N/A" : row[:llm_value] %></td>
          <td><%= row[:absolute_error].nil? ? "N/A" : row[:absolute_error] %></td>
          <td>
            <% if row[:passed] == true %>
              <span class="badge badge-resolved">PASS</span>
            <% elsif row[:passed] == false %>
              <span class="badge badge-open">FAIL</span>
            <% else %>
              <span class="badge">N/A</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
